}
body {
	overflow-y: auto;
}

.slider {
  display: flex;
  width: 100vw;
  height: 100vh;
  overflow-x: scroll;
  scroll-snap-type: x mandatory;
}
.overallslide { 
    display: block; 
  overflow-y: scroll;  
  height: 100vh;      
  scroll-snap-type: y mandatory;
}
.element-scroll{
    min-width: 100vw;
  height: 100vh;
  scroll-snap-align: start;
}
section {
  min-width: 100vw;
  height: 100vh;
  scroll-snap-align: start;
}


