    <style>
.overlay {
        height: 100%;
        width: 0;
        pointer-events: auto;
        z-index: 10000; 
        left: 0;
        top: 0;
        background-color: rgba(0, 0, 0, 0.9);
        overflow-x: hidden;
        transition: 0.5s;
      }
 
 .overlay-content {
   position: relative;
   top: 25%; 
   width: 100%; 
   text-align: center; 
   margin-top: 30px; 
 }

 .overlay a {
   padding: 8px;
   text-decoration: none;
   font-size: 36px;
   color: #818181;
   display: block; 
   transition: 0.3s; 
 }
 

 .overlay a:hover, .overlay a:focus {
   color: #f1f1f1;
 }

 .overlay .closebtn {
   position: absolute;
   top: 20px;
   right: 45px;
   font-size: 60px;
 }
 
 
 @media screen and (max-height: 450px) {
   .overlay a {font-size: 20px}
   .overlay .closebtn {
     font-size: 40px;
     top: 15px;
     right: 35px;
   }
 }
body {


  font-family: Arial, Helvetica, sans-serif;
}

@keyframes backgroundScroll {
  from {
    background-position: 0 0; /* Start at top-left */
  }
  to {
    background-position: -400px 0; /* Move 400px to the left */
  }
}

@keyframes burst {
    0% {
        transform: translate(-50%, -50%) scale(0);
        opacity: 1;
    }
    70% {
        opacity: 0.8;
    }
    100% {
        transform: translate(-50%, -50%) scale(1.5);
        opacity: 0;
    }
}
.page_title { 
  pointer-events: auto;
}
.masked-title {
    font-size: 8rem;
    font-weight: bold;
    color: transparent;
    pointer-events:auto;
    background-image: url('https://www.mrlocalhistory.org/wp-content/uploads/2019/04/Charter_Day_Ariel.jpg'); 
    background-size: 200%; /* Enlarged for smooth animation */
    background-position: 0 50%;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: animate-background 5s infinite alternate linear;
    color:black;
}
.masked-title-2 {
    font-size: 8rem;
    font-weight: bold;
    color: transparent;
    pointer-events:auto;
    background-image: url('https://www.shutterstock.com/image-photo/basking-ridge-nj-aerial-view-600nw-2468803517.jpg'); 
    background-size: 200%; /* Enlarged for smooth animation */
    background-position: 0 50%;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: animate-background 5s infinite alternate linear;
    color:black;
}
.masked-title-3 {
    font-size: 6rem;
    font-weight: bold;
    color: transparent;
    pointer-events:auto;
    background-image: url('data:image/jpeg;base64,'); 
    background-size: 200%; /* Enlarged for smooth animation */
    background-position: 0 50%;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: animate-background 5s infinite alternate linear;
    color:black;
}
.element-scroll {
  opacity: 0;
  transform: translateY(40px);
  transition: all 0.8s ease;
}

.element-scroll.show {
  opacity: 1;
  transform: translateY(0);
}

@keyframes animate-background {
    0% {
        background-position: 0 50%;
    }
    100% {
        background-position: 100% 50%;
    }
}

.section {
    scroll-snap-align: start; 
}

  .page_title {
  display:flex;
  justify-content:center;

  font-weight: 400;
  font-style: normal;
  text-align:center;
  border-color: white;
  transition: transform 0.5s ease-out;
  will-change: transform; 
  font-size:30px;
  z-index: 2;

      }
      .page_title :hover { 
       /* transform: scale(1.1); */
       text-shadow: rgb(223, 198, 181);
     
       
      }
      .page_title:hover::before,
.page_title:hover::after {
    content: '';
    position: absolute;
    top: 50%;
  scroll-padding-top:10px;
    left: 50%;
    width: 200%;
    height: 200%;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0);
    /* animation: burst 0.8s ease-out forwards; */
}

.page_title:hover::before {
    background: radial-gradient(circle, rgb(213, 193, 177), transparent);
    z-index: -1;
}

.page_title:hover::after {
    background: radial-gradient(circle, rgba(0, 200, 255, 0.6), transparent);
    z-index: -2;
}

@keyframes burst {
    0% {
        transform: translate(-50%, -50%) scale(0);
        opacity: 1;
    }
    70% {
        opacity: 0.8;
    }
    100% {
        transform: translate(-50%, -50%) scale(1.5);
        opacity: 0;
    }
}
.container { 
position:fixed;
